# LDAP / Active Directory Konfigürasyonu
LDAP_ENABLED=True
LDAP_SERVER=dc.ttnet.local
LDAP_PORT=389
LDAP_BASE_DN=dc=ttnet,dc=local
LDAP_USE_SSL=False
LDAP_TIMEOUT=10

# İzin verilen AD grupları (virgülle ayrılmış)
LDAP_ALLOWED_GROUPS=TTNET\DWH_ADMINS_BO,TTNET\BO_Upload_Users

# Oracle Veritabanı
ORACLE_USER=system
ORACLE_PASSWORD=1998
ORACLE_HOST=localhost
ORACLE_PORT=1521
ORACLE_SERVICE_NAME=XEPDB1

# Flask
FLASK_SECRET_KEY=your-secret-key-here-change-in-production

