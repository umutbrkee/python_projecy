		[HttpPost]
		[Authorize(Roles = Constants.AllowedGroups)]
		public ActionResult Save(int applicationId, int filterId, int? outputTypeId, string description, HttpPostedFileBase file)
		{
			if (string.IsNullOrWhiteSpace(description))
				throw new PortalUserException("Lütfen açıklama alanını doldurunuz.");

			if (file == null)
				throw new PortalUserException("Lütfen yüklemek istediğiniz dosyayı seçiniz.");

			var uploadService = new UploadService();
			string filePath = Config.AppSettings.UploadFolder;
			
			string username = UploadUtility.GetUsername(User.Identity.Name);
			string userip = Request.UserHostAddress;

			string applicationCode = DefinitionProvider.GetApplication(applicationId).Code;
			string filterCode = DefinitionProvider.GetFilter(filterId).Code;
			string outputCode = string.Empty;
				if(outputTypeId!=null)
				outputCode = DefinitionProvider.GetOutputType((int)outputTypeId).Code;

			string sftpUrl = Config.AppSettings.SftpUrl;
			string sftpUser = Config.AppSettings.SftpUser;
			string sftpPassword = Config.AppSettings.SftpPassword;
			string sftpDirectory = Config.AppSettings.SftpDirectory;

			var result = uploadService.UploadFile(username, userip, applicationCode, filterCode, outputCode, description, filePath, file.FileName, file.InputStream,
													sftpUrl, sftpUser, sftpPassword, sftpDirectory);

			if (result.UploadStatus == Domain.Enums.UploadStatuses.Failed)
				return PortalJsonResult(PortalResponseTypes.error, result.ErrorMessage);

			return PortalJsonResult(PortalResponseTypes.success, string.Format("Dosya başarıyla sunucuya alınmıştır. Ticket numarası:{0}", result.Ticket));
		}

