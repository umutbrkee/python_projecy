		[Authorize(Roles = Constants.AllowedGroups)]
		public ActionResult GetUploads(GridFilter gridFilter)
        
        {
            var uploadService = new UploadService();
			string username = UploadUtility.GetUsername(User.Identity.Name);

			switch (gridFilter.sortField)
			{
				case "ApplicationName":
					gridFilter.sortField = "APPLICATIONCODE";
					break;
				case "FilterName":
					gridFilter.sortField = "FILTERCODE";
					break;
				case "OutputTypeName":
					gridFilter.sortField = "OUTPUTCODE";
					break;
				case "StatusName":
					gridFilter.sortField = "XU_UPLOADSTATUS.NAME";
					break;
			}

			//var uploads = uploadService.GetUploads(username, gridFilter);
            /*FD 20180918 Yukarıdaki teradata kodu kapatılıp, exadata'dan çalışacak şekilde oracle ekli func'lar yazıldı.*/
            var uploads = uploadService.GetUploadsOracle(username, gridFilter);

            var uploadList =
				from u in uploads
				select new UploadListModel
				{
					TicketNo = (long)u.TICKETNO,
					ApplicationName = DefinitionProvider.GetApplication(u.APPLICATIONCODE).Name,
					FilterName = DefinitionProvider.GetFilter(u.FILTERCODE).Name,
					OutputTypeName = !string.IsNullOrEmpty(u.OUTPUTCODE) ? DefinitionProvider.GetOutputType(u.OUTPUTCODE).Name : string.Empty,
					Description = u.DESCRIPTION,
					UploadStartDate = u.UPLOADSTARTDATE.ToString(),
					UploadEndDate = (u.UPLOADENDDATE != null ? u.UPLOADENDDATE.ToString() : string.Empty),
					StatusName = u.XU_UPLOADSTATUS.NAME,
					RowCount = u.ROWCOUNT,
					FileName = u.FILENAME
				};

			//var uploadCount = uploadService.GetUploadCount(username);
            /*FD 20180918 Yukarıdaki teradata kodu kapatılıp, exadata'dan çalışacak şekilde oracle ekli func'lar yazıldı.*/
            var uploadCount = uploadService.GetUploadCountOracle(username);
            
            return Json(new
			{
				data = uploadList.ToList(),
				itemsCount = uploadCount
			}, JsonRequestBehavior.AllowGet);
		}

